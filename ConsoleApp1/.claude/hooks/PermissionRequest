#!/bin/bash
# Claude Code PermissionRequest Hook
# 匹配 Claude Code 实际 JSON 格式，弹窗选项与终端一致

NOTIFY_APP="C:/Users/Administrator/Desktop/claudecode全局hooks/ConsoleApp1/ConsoleApp1/bin/Release/net8.0-windows/ConsoleApp1.exe"

if [ ! -f "$NOTIFY_APP" ]; then
    NOTIFY_APP="${NOTIFY_APP/\/Release\//\/Debug\/}"
    if [ ! -f "$NOTIFY_APP" ]; then
        exit 0
    fi
fi

INPUT=$(cat 2>/dev/null || true)
if [ -z "$INPUT" ]; then
    exit 0
fi

RESULT_FILE=$(mktemp -p /tmp claude_result_XXXXXX.txt 2>/dev/null || echo "/tmp/claude_result_$$.txt")

TITLE=""
MSG=""
ACTIONS=""

PARSED=$(PYTHONIOENCODING=utf-8 python3 -c "
import sys, json

d = json.loads(sys.stdin.read())
ti = d.get('tool_input', {})
desc = ti.get('description', '') or ''
cmd = ti.get('command', '') or ''
tool = d.get('tool_name', '') or ''

# 构建消息
if cmd:
    c = cmd[:120] + ('...' if len(cmd) > 120 else '')
    msg = f'[{tool}] {c}' if tool else c
    if desc and desc != cmd:
        msg = f'{desc}\n{c}'
else:
    msg = desc or f'[{tool}] 需要授权'

title = f'Claude Code — {tool} 权限' if tool else 'Claude Code — 权限请求'

# 根据 suggestion 动态决定选项数
# localSettings = 可持久化记住 → 3 选项: Allow / Allow and remember / Deny
# session = 仅本次 / 无 suggestion → 2 选项: Allow / Deny
suggestions = d.get('permission_suggestions', [])
has_local = any(s.get('destination') == 'localSettings' for s in suggestions) if suggestions else False
if has_local:
    actions = 'Allow|allow||Allow and remember|allowRemember||Deny|deny'
else:
    actions = 'Allow|allow||Deny|deny'

print(f'TITLE:{title}')
print(f'MSG:{msg}')
print(f'ACTIONS:{actions}')
" 2>/dev/null <<< "$INPUT" || true)

# Bash 解析
if [ -n "$PARSED" ]; then
    while IFS=: read -r key value; do
        value="${value%%[$'\r']*}"
        case "$key" in
            TITLE) [ -n "$value" ] && TITLE="$value" ;;
            MSG) [ -n "$value" ] && MSG="$value" ;;
            ACTIONS) [ -n "$value" ] && ACTIONS="$value" ;;
        esac
    done <<< "$PARSED"
fi

if [ -z "$MSG" ]; then MSG="请查看终端进行操作"; fi
if [ -z "$ACTIONS" ]; then ACTIONS="Allow|allow||Deny|deny"; fi

# 启动弹窗并等待
"$NOTIFY_APP" \
    --title "$TITLE" \
    --msg "$MSG" \
    --type permission \
    --actions "$ACTIONS" \
    --result-file "$RESULT_FILE" \
    --timeout 30 \
    --sound on \
    >/dev/null 2>&1

# 读取结果
RESULT=""
if [ -f "$RESULT_FILE" ]; then
    RESULT=$(sed 's/^\xef\xbb\xbf//' "$RESULT_FILE" 2>/dev/null | tr -d '[:space:]' || cat "$RESULT_FILE")
fi

# 输出响应
if [ -n "$RESULT" ]; then
    case "$RESULT" in
        allow)
            echo '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"allow"}}}'
            ;;
        allowRemember)
            echo '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"allow"}}}'
            ;;
        deny)
            echo '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"deny","message":"User denied via notification","interrupt":true}}}'
            ;;
    esac
fi

rm -f "$RESULT_FILE" 2>/dev/null || true
exit 0
